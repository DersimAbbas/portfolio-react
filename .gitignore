# =============================================
# React + .NET Fullstack .gitignore
# =============================================

# ----- Dependencies -----
node_modules/
.pnp/
.pnp.js

# ----- Build outputs -----
# React
build/
dist/
out/
.next/
.nuxt/
.output/

# .NET
bin/
obj/
publish/
artifacts/
*.dll
*.exe
*.pdb
*.cache

# ----- Environment & secrets -----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
appsettings.Development.json
appsettings.Local.json
secrets.json
*.pfx
*.key

# ----- IDE & editors -----
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates
.idea/
*.swp
*.swo
*~

# ----- OS files -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----- Testing -----
coverage/
*.lcov
.nyc_output/
TestResults/

# ----- Package manager -----
package-lock.json
yarn.lock
pnpm-lock.yaml

# ----- Misc -----
*.tmp
*.temp
*.bak
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
